# OpenAlex polite pool (recommended — increases rate limit from 10 to 100 req/s)
OPENALEX_EMAIL=your@email.com

# Optional premium API key
OPENALEX_API_KEY=

# llama.cpp local LLM server (OpenAI-compatible)
# Start with: llama-server -m /path/to/model.gguf --port 8080
LLAMA_BASE_URL=http://localhost:8080
LLAMA_MODEL=local
LLAMA_MAX_TOKENS=512
LLAMA_TIMEOUT=60.0

# Embeddings
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
EMBEDDINGS_BATCH_SIZE=64

# Search defaults
DEFAULT_K=10
RRF_K=60
RAG_TOP_K=5

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
